# Database
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fulcrum
DB_CONNECTION_STRING=Host=postgres;Database=fulcrum;Username=postgres;Password=postgres

# Redis
REDIS_PASSWORD=redis
REDIS_CONNECTION_STRING=redis:6379,password=redis

# JWT
JWT_SECRET_KEY=your-super-secret-key-that-is-at-least-32-chars!!
JWT_ISSUER=identity-service
JWT_AUDIENCE=api.fulcrum.com
JWT_EXPIRY_MINUTES=60

# Image
GITHUB_REPOSITORY=yourname/fulcrum-backend
IMAGE_TAG=local
